{
  "name": "@localstack/localstack-mcp-server",
  "version": "0.3.0",
  "mcpName": "io.github.localstack/localstack-mcp-server",
  "description": "A LocalStack MCP Server for managing LocalStack containers with Pro support",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "xmcp build",
    "dev": "xmcp dev",
    "start": "node dist/stdio.js",
    "format": "prettier --write .",
    "test": "jest",
    "test:mcp:direct": "yarn build && playwright test -c playwright.config.mjs tests/mcp/direct.spec.mjs",
    "test:mcp:evals": "yarn build && playwright test -c playwright.config.mjs tests/mcp/evals-gemini.spec.mjs",
    "test:mcp": "yarn test:mcp:direct && yarn test:mcp:evals"
  },
  "dependencies": {
    "dockerode": "^4.0.7",
    "posthog-node": "5.0.0",
    "xmcp": "0.6.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@gleanwork/mcp-server-tester": "1.0.0-beta.6",
    "@playwright/test": "^1.58.2",
    "@types/dockerode": "^3.3.43",
    "@types/jest": "^30.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "swc-loader": "^0.2.6",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "main": "./dist/stdio.js",
  "files": [
    "dist"
  ],
  "bin": {
    "localstack-mcp-server": "./dist/stdio.js"
  },
  "author": "@localstack",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/localstack/localstack-mcp-server"
  },
  "keywords": [
    "localstack",
    "aws",
    "local-development",
    "local-testing"
  ]
}
